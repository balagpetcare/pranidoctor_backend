/// Global feed master catalog. Admin-managed; farmers link via optional InventoryItem.feedCatalogId.
model FeedCatalog {
  id                String       @id @default(cuid())
  code              String       @unique
  nameBn            String
  nameEn            String
  category          FeedCategory
  defaultUnit       FeedUnit
  approxPriceBdt    Decimal?     @db.Decimal(12, 2)
  nutritionJson     Json?
  availabilityScore Int?
  isSeeded          Boolean      @default(false)
  isActive          Boolean      @default(true)
  sortOrder         Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  inventoryItems    InventoryItem[]

  @@index([category, isActive])
  @@index([isActive, sortOrder])
}

model FeedRecord {
  id                    String          @id @default(cuid())
  customerId            String
  farmRef               String?
  animalId              String?
  /// Legacy free-text / local group batch key.
  batchId               String?
  batchName             String?
  /// FK to fattening batch when logged from cattle fattening flow.
  fatteningBatchId      String?
  /// Optional link to farm feed inventory (V1).
  inventoryItemId       String?
  inventoryTransactionId String?        @unique
  deductStock           Boolean         @default(false)
  feedType              FeedType
  amount                Decimal         @db.Decimal(10, 3)
  unit                  FeedUnit
  costBdt               Decimal?        @db.Decimal(12, 2)
  recordedDate          DateTime        @db.Date
  notes                 String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  customer              CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  animal                AnimalProfile?  @relation(fields: [animalId], references: [id], onDelete: SetNull)
  fatteningBatch        FatteningBatch? @relation(fields: [fatteningBatchId], references: [id], onDelete: SetNull)
  inventoryItem         InventoryItem?  @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  inventoryTransaction  InventoryTransaction? @relation("FeedInventoryTransaction", fields: [inventoryTransactionId], references: [id], onDelete: SetNull)

  @@index([customerId, recordedDate])
  @@index([animalId])
  @@index([feedType])
  @@index([fatteningBatchId, recordedDate])
  @@index([inventoryItemId])
}

