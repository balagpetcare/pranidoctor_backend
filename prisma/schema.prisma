generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                                String                      @id @default(cuid())
  email                             String                      @unique
  phone                             String?                     @unique
  passwordHash                      String
  role                              UserRole
  status                            UserStatus                  @default(ACTIVE)
  createdAt                         DateTime                    @default(now())
  updatedAt                         DateTime                    @updatedAt
  adminProfile                      AdminProfile?
  aiAssistantSessions               AiAssistantSession[]
  customerAiServiceRecords          AiServiceRecord[]           @relation("AiServiceRecordCustomer")
  customerAiServiceRequests         AiServiceRequest[]          @relation("AiServiceRequestCustomer")
  aiTechnicianModuleComplaintsFiled AiTechnicianComplaint[]     @relation("AiTechnicianComplaintAuthor")
  aiTechnicianProfilesReviewed      AiTechnicianProfile[]       @relation("AiTechnicianProfileReviewedBy")
  aiTechnicianProfile               AiTechnicianProfile?
  aiTechnicianModuleReviewsWritten  AiTechnicianReview[]        @relation("AiTechnicianReviewAuthor")
  authAuditEvents                   AuthAuditEvent[]
  complaintsAssigned                Complaint[]                 @relation("ComplaintAssignee")
  contentPostsAuthored              ContentPost[]               @relation("ContentPostAuthor")
  customerProfile                   CustomerProfile?
  doctorProfile                     DoctorProfile?
  notifications                     Notification[]
  notificationSettings              NotificationSettings?
  mobileUserSettings                MobileUserSettings?
  offlineConflictRecords            OfflineConflictRecord[]
  offlineLeadDrafts                 OfflineLeadDraft[]
  offlineSyncItems                  OfflineSyncItem[]
  offlineSyncSessions               OfflineSyncSession[]
  semenTemplatesApproved            SemenServiceTemplate[]      @relation("SemenTemplateApprovedBy")
  serviceInstancesLastReviewed      ServiceInstance[]           @relation("ServiceInstanceLastReviewedBy")
  serviceInstanceAuditEvents        ServiceInstanceAuditEvent[]
  serviceInstancePublishLogs        ServiceInstancePublishLog[]
  serviceInstanceReviews            ServiceInstanceReview[]
  serviceInstanceStatusLogs         ServiceInstanceStatusLog[]
  uploadedFiles                     UploadedFile[]
  voiceSessions                     VoiceSession[]
  refreshTokens                     RefreshToken[]
  userDevices                       UserDevice[]
  userSessions                      UserSession[]
  legalConsentEvents                LegalConsentEvent[]
  legalAcceptanceEvents             LegalAcceptanceEvent[]

  @@index([role])
  @@index([status])
  @@index([role, status])
}

/// P1-06 — mobile device registry (push, revoke).
model UserDevice {
  id            String         @id @default(cuid())
  userId        String
  deviceKey     String
  platform      String?
  pushToken     String?
  appVersion    String?
  lastActiveAt  DateTime       @default(now())
  revokedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions      UserSession[]

  @@unique([userId, deviceKey])
  @@index([userId])
  @@map("user_devices")
}

/// P1-06 — revocable server session (linked to refresh tokens).
model UserSession {
  id            String         @id @default(cuid())
  userId        String
  channel       AuthChannel
  status        SessionStatus  @default(ACTIVE)
  deviceId      String?
  ipAddress     String?
  userAgent     String?
  expiresAt     DateTime
  lastSeenAt    DateTime       @default(now())
  revokedAt     DateTime?
  revokedReason String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  device        UserDevice?    @relation(fields: [deviceId], references: [id])
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, channel])
  @@index([userId, status])
  @@index([expiresAt])
  @@map("user_sessions")
}

/// P1-06 — hashed refresh token with rotation.
model RefreshToken {
  id          String      @id @default(cuid())
  userId      String
  sessionId   String
  tokenHash   String      @unique
  channel     AuthChannel @default(MOBILE)
  deviceId    String?
  expiresAt   DateTime
  revoked     Boolean     @default(false)
  revokedAt   DateTime?
  rotatedAt   DateTime?
  rotatedToId String?
  lastUsedAt  DateTime?
  createdAt   DateTime    @default(now())
  device      UserDevice? @relation(fields: [deviceId], references: [id])
  session     UserSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([expiresAt])
  @@index([revoked])
  @@map("refresh_tokens")
}

model AdminProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DoctorProfile {
  id                             String                         @id @default(cuid())
  userId                         String                         @unique
  licenseNumber                  String
  specialization                 String?
  bio                            String?
  verifiedAt                     DateTime?
  createdAt                      DateTime                       @default(now())
  updatedAt                      DateTime                       @updatedAt
  providerStatus                 ProviderStatus                 @default(PENDING_VERIFICATION)
  acceptsEmergency               Boolean                        @default(false)
  acceptsOnlineConsultation      Boolean                        @default(false)
  degree                         String?
  /// Display name shown to customers (identity email/phone stay on `User`).
  displayName                    String?
  /// Years of professional experience (optional).
  experienceYears                Int?
  /// Placeholder or CDN URL for profile photo until uploads exist.
  profilePhotoUrl                String?
  visitFeeBdt                    Decimal?                       @db.Decimal(12, 2)
  billingRecords                 BillingRecord[]
  complaints                     Complaint[]
  user                           User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctorProfileAreas             DoctorProfileArea[]
  doctorProfileServiceCategories DoctorProfileServiceCategory[]
  doctorServiceAreas             DoctorServiceArea[]
  prescriptions                  Prescription[]
  reviews                        Review[]
  assignedRequests               ServiceRequest[]
  treatmentConsultations         TreatmentConsultation[]
  treatmentFollowups             TreatmentFollowup[]
  treatmentNotesAuthored         TreatmentNote[]                @relation("TreatmentNoteAuthor")
  treatmentCases                 TreatmentCase[]
  treatmentWorkflows             TreatmentWorkflow[]

  @@index([providerStatus])
}

model AiTechnicianProfile {
  id                                   String                               @id @default(cuid())
  userId                               String                               @unique
  certification                        String?
  bio                                  String?
  providerStatus                       ProviderStatus                       @default(PENDING_VERIFICATION)
  verifiedAt                           DateTime?
  createdAt                            DateTime                             @default(now())
  updatedAt                            DateTime                             @updatedAt
  /// Offers urgent / after-hours field AI support (dispatch rules live in product logic).
  acceptsEmergency                     Boolean                              @default(false)
  /// Display name shown to customers (identity email/phone stay on `User`).
  displayName                          String?
  /// Optional tags for MVP: e.g. livestock breeds, semen services (`{ "livestockFocus": ["cattle"], "semenServices": true }`).
  metadataJson                         Json?
  /// Default fee for AI / technician field services (BDT).
  serviceFeeBdt                        Decimal?                             @db.Decimal(12, 2)
  adminNote                            String?
  certificateNumber                    String?
  correctionNote                       String?
  dateOfBirth                          DateTime?
  district                             String?
  /// Optional public contact; canonical email remains on `User.email`.
  email                                String?
  experienceYears                      Int?
  gender                               Gender?
  nidNumber                            String?
  /// Optional public contact; canonical phone remains on `User.phone` when set.
  phone                                String?
  presentAddress                       String?
  publishedAt                          DateTime?
  reviewedAt                           DateTime?
  reviewedById                         String?
  /// Admin / onboarding lifecycle for technician module (see `AiTechnicianStatus`).
  status                               AiTechnicianStatus                   @default(UNDER_REVIEW)
  trainingProvider                     String?
  unionOrArea                          String?
  upazila                              String?
  /// Optional FKs to normalized `District` / `Upazila` / `Union` (COMMAND 02). Legacy `district` / `upazila` / `unionOrArea` text retained.
  districtId                           String?
  unionId                              String?
  upazilaId                            String?
  aiServiceRecords                     AiServiceRecord[]
  aiServiceRequests                    AiServiceRequest[]                   @relation("AiServiceRequestTechnician")
  moduleComplaints                     AiTechnicianComplaint[]              @relation("AiTechnicianModuleComplaint")
  divisionCoverageAreas                AiTechnicianDivisionServiceArea[]
  documents                            AiTechnicianDocument[]
  bdDistrict                           District?                            @relation("AiTechnicianProfileDistrict", fields: [districtId], references: [id])
  reviewedBy                           User?                                @relation("AiTechnicianProfileReviewedBy", fields: [reviewedById], references: [id])
  bdUnion                              Union?                               @relation("AiTechnicianProfileUnion", fields: [unionId], references: [id])
  bdUpazila                            Upazila?                             @relation("AiTechnicianProfileUpazila", fields: [upazilaId], references: [id])
  user                                 User                                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiTechnicianProfileAreas             AiTechnicianProfileArea[]
  aiTechnicianProfileServiceCategories AiTechnicianProfileServiceCategory[]
  moduleReviews                        AiTechnicianReview[]                 @relation("AiTechnicianModuleReview")
  technicianServices                   AiTechnicianService[]
  aiTechnicianServiceAreas             AiTechnicianServiceArea[]
  billingRecords                       BillingRecord[]
  complaints                           Complaint[]
  prescriptions                        Prescription[]
  reviews                              Review[]
  serviceInstances                     ServiceInstance[]
  assignedRequests                     ServiceRequest[]
  treatmentCases                       TreatmentCase[]

  @@index([providerStatus])
  @@index([status])
  @@index([reviewedById])
  @@index([districtId])
  @@index([upazilaId])
  @@index([unionId])
}

model CustomerProfile {
  id                 String           @id @default(cuid())
  userId             String           @unique
  displayName        String
  locale             String?          @default("bn-BD")
  addressJson        Json?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  /// HTTPS URL to display asset (same-origin `/api/mobile/uploads/:id` redirect or CDN).
  profilePhotoUrl       String?
  profilePhotoThumbUrl  String?
  coverPhotoUrl         String?
  coverPhotoThumbUrl    String?
  /// P2 — denormalized village FK for service matching (optional).
  primaryVillageId   String?
  profileCompletedAt DateTime?
  animals            AnimalProfile[]
  milkRecords        MilkRecord[]
  feedRecords        FeedRecord[]
  financeRecords     FinanceRecord[]
  healthEvents       HealthEvent[]
  vaccineRecords     VaccineRecord[]
  farmTreatments     FarmTreatment[]
  fatteningBatches   FatteningBatch[]
  fatteningBatchRois FatteningBatchRoi[]
  weightRecords      WeightRecord[]
  batchFeedPlans     BatchFeedPlan[]
  inventoryItems     InventoryItem[]
  inventoryTransactions InventoryTransaction[]
  inventoryAuditLogs InventoryAuditLog[]
  livestockRecords   Livestock[]
  livestockExpenses  LivestockExpense[]
  feedInventories    FeedInventory[]
  feedPurchases      FeedPurchase[]
  feedConsumptions   FeedConsumption[]
  feedRecommendationLogs FeedRecommendationLog[]
  feedAnalyticsCaches FeedAnalyticsCache[]
  livestockAuditLogs LivestockAuditLog[]
  smartRecommendations SmartRecommendation[]
  dewormingRecords   DewormingRecord[]
  farmRiskSnapshots  FarmRiskSnapshot[]
  aiSmartAlerts      AiSmartAlert[]
  supportTickets     SupportTicket[]
  billingRecords     BillingRecord[]
  complaints         Complaint[]
  primaryVillage     Village?         @relation("CustomerPrimaryVillage", fields: [primaryVillageId], references: [id])
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews            Review[]
  serviceRequests    ServiceRequest[]

  @@index([primaryVillageId])
}

/// One active OTP challenge per normalized Bangladesh mobile (customer login).
model MobileOtpChallenge {
  id                  String    @id @default(cuid())
  normalizedPhone     String    @unique
  codeHash            String
  expiresAt           DateTime
  verifyAttempts      Int       @default(0)
  sendWindowStartedAt DateTime?
  sendsInWindow       Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  /// Last time an OTP was successfully issued (for resend cooldown).
  lastOtpSentAt       DateTime?

  @@index([expiresAt])
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Division {
  id         String     @id @default(cuid())
  /// Legacy display label (English-oriented seeds). Prefer `nameEn` / `nameBn` when set.
  name       String
  slug       String     @unique
  /// Not globally unique in legacy / merged seeds; match on slug + hierarchy when needed.
  code       String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  isActive   Boolean    @default(true)
  nameBn     String?
  nameEn     String?
  sortOrder  Int        @default(0)
  isVerified Boolean    @default(false)
  /// Centroid or verified point; null if unknown (never guessed).
  latitude   Decimal?   @db.Decimal(10, 7)
  longitude  Decimal?   @db.Decimal(10, 7)
  /// Provenance, e.g. dataset id/version.
  source     String?
  districts  District[]

  @@index([isActive])
  @@index([nameBn])
  @@index([nameEn])
  @@index([code])
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model District {
  id                                String                            @id @default(cuid())
  divisionId                        String
  /// Legacy display label. Prefer `nameEn` / `nameBn` when set.
  name                              String
  slug                              String                            @unique
  code                              String?
  createdAt                         DateTime                          @default(now())
  updatedAt                         DateTime                          @updatedAt
  isActive                          Boolean                           @default(true)
  nameBn                            String?
  nameEn                            String?
  sortOrder                         Int                               @default(0)
  isVerified                        Boolean                           @default(false)
  latitude                          Decimal?                          @db.Decimal(10, 7)
  longitude                         Decimal?                          @db.Decimal(10, 7)
  source                            String?
  aiTechnicianDivisionAreasDistrict AiTechnicianDivisionServiceArea[] @relation("DivisionServiceAreaDistrict")
  aiTechnicianProfilesAsDistrict    AiTechnicianProfile[]             @relation("AiTechnicianProfileDistrict")
  division                          Division                          @relation(fields: [divisionId], references: [id])
  upazilas                          Upazila[]

  @@index([divisionId])
  @@index([isActive])
  @@index([divisionId, code])
  @@index([divisionId, nameBn])
  @@index([divisionId, nameEn])
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Upazila {
  id                               String                            @id @default(cuid())
  districtId                       String
  name                             String
  slug                             String                            @unique
  code                             String?
  createdAt                        DateTime                          @default(now())
  updatedAt                        DateTime                          @updatedAt
  isActive                         Boolean                           @default(true)
  nameBn                           String?
  nameEn                           String?
  sortOrder                        Int                               @default(0)
  isVerified                       Boolean                           @default(false)
  latitude                         Decimal?                          @db.Decimal(10, 7)
  longitude                        Decimal?                          @db.Decimal(10, 7)
  source                           String?
  aiTechnicianDivisionAreasUpazila AiTechnicianDivisionServiceArea[] @relation("DivisionServiceAreaUpazila")
  aiTechnicianProfilesAsUpazila    AiTechnicianProfile[]             @relation("AiTechnicianProfileUpazila")
  unions                           Union[]
  district                         District                          @relation(fields: [districtId], references: [id])

  @@index([districtId])
  @@index([isActive])
  @@index([districtId, code])
  @@index([districtId, nameBn])
  @@index([districtId, nameEn])
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Union {
  id                             String                            @id @default(cuid())
  upazilaId                      String
  name                           String
  slug                           String                            @unique
  code                           String?
  createdAt                      DateTime                          @default(now())
  updatedAt                      DateTime                          @updatedAt
  isActive                       Boolean                           @default(true)
  nameBn                         String?
  nameEn                         String?
  sortOrder                      Int                               @default(0)
  isVerified                     Boolean                           @default(false)
  latitude                       Decimal?                          @db.Decimal(10, 7)
  longitude                      Decimal?                          @db.Decimal(10, 7)
  source                         String?
  aiTechnicianDivisionAreasUnion AiTechnicianDivisionServiceArea[] @relation("DivisionServiceAreaUnion")
  aiTechnicianProfilesAsUnion    AiTechnicianProfile[]             @relation("AiTechnicianProfileUnion")
  upazila                        Upazila                           @relation(fields: [upazilaId], references: [id])
  villages                       Village[]

  @@index([upazilaId])
  @@index([isActive])
  @@index([upazilaId, code])
  @@index([upazilaId, nameBn])
  @@index([upazilaId, nameEn])
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Village {
  id                       String                    @id @default(cuid())
  unionId                  String
  /// Legacy single label; prefer `nameBn` / `nameEn` when set.
  name                     String
  slug                     String                    @unique
  code                     String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  isActive                 Boolean                   @default(true)
  isVerified               Boolean                   @default(false)
  latitude                 Decimal?                  @db.Decimal(10, 7)
  longitude                Decimal?                  @db.Decimal(10, 7)
  nameBn                   String?
  nameEn                   String?
  source                   String?
  aiTechnicianServiceAreas AiTechnicianServiceArea[]
  customerPrimaryVillages  CustomerProfile[]         @relation("CustomerPrimaryVillage")
  doctorServiceAreas       DoctorServiceArea[]
  serviceRequests          ServiceRequest[]
  union                    Union                     @relation(fields: [unionId], references: [id])

  @@index([unionId])
  @@index([unionId, nameBn])
  @@index([unionId, nameEn])
  @@index([isActive])
}

/// Unified hierarchical area tree for Bangladesh geography (admin/API).
/// Coexists with normalized `Division`…`Village` tables; `ServiceRequest.areaId` remains optional during migration.
model Area {
  id                       String                    @id @default(cuid())
  name                     String
  slug                     String                    @unique
  parentId                 String?
  metadataJson             Json?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  code                     String?
  isActive                 Boolean                   @default(true)
  nameBn                   String?
  sortOrder                Int                       @default(0)
  type                     AreaType                  @default(DIVISION)
  aiTechnicianProfileAreas AiTechnicianProfileArea[]
  parent                   Area?                     @relation("AreaHierarchy", fields: [parentId], references: [id])
  children                 Area[]                    @relation("AreaHierarchy")
  doctorProfileAreas       DoctorProfileArea[]
  serviceRequests          ServiceRequest[]

  @@index([parentId])
  @@index([type])
  @@index([isActive])
  @@index([parentId, type])
}

model DoctorServiceArea {
  id        String        @id @default(cuid())
  doctorId  String
  villageId String
  priority  Int?
  createdAt DateTime      @default(now())
  doctor    DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  village   Village       @relation(fields: [villageId], references: [id], onDelete: Cascade)

  @@unique([doctorId, villageId])
  @@index([villageId])
}

model AiTechnicianServiceArea {
  id             String              @id @default(cuid())
  aiTechnicianId String
  villageId      String
  priority       Int?
  createdAt      DateTime            @default(now())
  aiTechnician   AiTechnicianProfile @relation(fields: [aiTechnicianId], references: [id], onDelete: Cascade)
  village        Village             @relation(fields: [villageId], references: [id], onDelete: Cascade)

  @@unique([aiTechnicianId, villageId])
  @@index([villageId])
}

model ServiceCategory {
  id                                   String                               @id @default(cuid())
  name                                 String
  slug                                 String                               @unique
  description                          String?
  createdAt                            DateTime                             @default(now())
  updatedAt                            DateTime                             @updatedAt
  aiTechnicianProfileServiceCategories AiTechnicianProfileServiceCategory[]
  doctorProfileServiceCategories       DoctorProfileServiceCategory[]
  serviceRequests                      ServiceRequest[]
}

/// Many-to-many: doctor coverage using the unified `Area` tree (admin geography).
model DoctorProfileArea {
  id        String        @id @default(cuid())
  doctorId  String
  areaId    String
  priority  Int?
  createdAt DateTime      @default(now())
  area      Area          @relation(fields: [areaId], references: [id], onDelete: Cascade)
  doctor    DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, areaId])
  @@index([areaId])
}

/// Many-to-many: AI technician coverage using the unified `Area` tree (parallel to `DoctorProfileArea`).
model AiTechnicianProfileArea {
  id             String              @id @default(cuid())
  aiTechnicianId String
  areaId         String
  priority       Int?
  createdAt      DateTime            @default(now())
  aiTechnician   AiTechnicianProfile @relation(fields: [aiTechnicianId], references: [id], onDelete: Cascade)
  area           Area                @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@unique([aiTechnicianId, areaId])
  @@index([areaId])
}

/// Many-to-many: which service categories a doctor offers.
model DoctorProfileServiceCategory {
  id                String          @id @default(cuid())
  doctorId          String
  serviceCategoryId String
  createdAt         DateTime        @default(now())
  doctor            DoctorProfile   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  serviceCategory   ServiceCategory @relation(fields: [serviceCategoryId], references: [id], onDelete: Cascade)

  @@unique([doctorId, serviceCategoryId])
  @@index([serviceCategoryId])
}

/// Many-to-many: which catalog services an AI technician provides (e.g. slug `ai-service`).
model AiTechnicianProfileServiceCategory {
  id                String              @id @default(cuid())
  aiTechnicianId    String
  serviceCategoryId String
  createdAt         DateTime            @default(now())
  aiTechnician      AiTechnicianProfile @relation(fields: [aiTechnicianId], references: [id], onDelete: Cascade)
  serviceCategory   ServiceCategory     @relation(fields: [serviceCategoryId], references: [id], onDelete: Cascade)

  @@unique([aiTechnicianId, serviceCategoryId])
  @@index([serviceCategoryId])
}

/// Declarative district-level service coverage (text labels or slugs).
/// Legacy village-level coverage remains on `AiTechnicianServiceArea`.
model AiTechnicianDivisionServiceArea {
  id             String              @id @default(cuid())
  aiTechnicianId String
  district       String
  upazila        String
  unionOrArea    String?
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  /// Optional FKs to normalized geography; text columns above remain for search / legacy clients.
  districtId     String?
  unionId        String?
  upazilaId      String?
  aiTechnician   AiTechnicianProfile @relation(fields: [aiTechnicianId], references: [id], onDelete: Cascade)
  bdDistrict     District?           @relation("DivisionServiceAreaDistrict", fields: [districtId], references: [id])
  bdUnion        Union?              @relation("DivisionServiceAreaUnion", fields: [unionId], references: [id])
  bdUpazila      Upazila?            @relation("DivisionServiceAreaUpazila", fields: [upazilaId], references: [id])

  @@index([aiTechnicianId])
  @@index([district, upazila])
  @@index([districtId])
  @@index([upazilaId])
  @@index([unionId])
}

model AiTechnicianDocument {
  id             String                           @id @default(cuid())
  aiTechnicianId String
  type           AiTechnicianDocumentType
  title          String
  /// Public or signed URL when objects are web-accessible.
  fileUrl        String?
  /// Opaque storage object key when using bucket-backed uploads.
  storageKey     String?
  mimeType       String?
  reviewStatus   AiTechnicianDocumentReviewStatus @default(PENDING_REVIEW)
  uploadedAt     DateTime                         @default(now())
  createdAt      DateTime                         @default(now())
  updatedAt      DateTime                         @updatedAt
  /// When set, file bytes and metadata live on `UploadedFile` (preferred path).
  uploadedFileId String?                          @unique
  aiTechnician   AiTechnicianProfile              @relation(fields: [aiTechnicianId], references: [id], onDelete: Cascade)
  uploadedFile   UploadedFile?                    @relation(fields: [uploadedFileId], references: [id])

  @@index([aiTechnicianId])
  @@index([type])
}

/// Object storage metadata for universal mobile uploads (S3 / MinIO–compatible).
model UploadedFile {
  id                   String                     @id @default(cuid())
  ownerUserId          String
  bucket               String
  storageKey           String                     @unique
  originalName         String
  mimeType             String
  sizeBytes            Int
  fileCategory         MobileUploadPurpose
  publicUrl            String?
  checksum             String?
  width                Int?
  height               Int?
  status               UploadedFileStatus         @default(ACTIVE)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  aiTechnicianDocument AiTechnicianDocument?
  semenProviderLogo    SemenProvider?
  semenTemplateMedia   SemenServiceTemplateMedia?
  serviceInstanceMedia ServiceInstanceMedia[]
  owner                User                       @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId])
  @@index([status])
  @@index([fileCategory])
}

/// Semen company / organization master (BRAC, ACI, DLS, etc.).
model SemenProvider {
  id                 String                          @id @default(cuid())
  slug               String                          @unique
  name               String
  nameBn             String?
  description        String?
  descriptionBn      String?
  logoUploadedFileId String?                         @unique
  isActive           Boolean                         @default(true)
  verificationStatus SemenProviderVerificationStatus @default(UNVERIFIED)
  sortOrder          Int                             @default(0)
  createdAt          DateTime                        @default(now())
  updatedAt          DateTime                        @updatedAt
  logoUploadedFile   UploadedFile?                   @relation(fields: [logoUploadedFileId], references: [id])
  templates          SemenServiceTemplate[]

  @@index([isActive])
  @@index([sortOrder])
}

/// Livestock breed master (Bangla + English); used in semen template composition.
model LivestockBreed {
  id            String                         @id @default(cuid())
  slug          String                         @unique
  nameEn        String
  nameBn        String
  animalType    AnimalType
  description   String?
  isActive      Boolean                        @default(true)
  createdAt     DateTime                       @default(now())
  updatedAt     DateTime                       @updatedAt
  templateMixes SemenServiceTemplateBreedMix[]

  @@index([animalType])
  @@index([isActive])
}

/// Admin-authored semen service template (locked fields for technician listings).
model SemenServiceTemplate {
  id                         String                         @id @default(cuid())
  internalName               String
  animalType                 AnimalType
  semenProviderId            String
  semenProductKind           SemenProductKind
  /// When `semenProductKind` is OTHER, short free-text label from admin.
  otherSemenLabel            String?
  shortDescription           String?
  detailedDescription        String?
  expectedBenefits           String?
  recommendedAnimalCondition String?
  warningsContraindications  String?
  defaultBasePrice           Decimal                        @db.Decimal(12, 2)
  defaultOfferPrice          Decimal?                       @db.Decimal(12, 2)
  defaultDiscountPercent     Decimal?                       @db.Decimal(5, 2)
  tagsJson                   Json?
  isActive                   Boolean                        @default(true)
  approvalStatus             SemenTemplateApprovalStatus    @default(DRAFT)
  approvedById               String?
  approvedAt                 DateTime?
  rejectedReason             String?
  createdAt                  DateTime                       @default(now())
  updatedAt                  DateTime                       @updatedAt
  technicianServices         AiTechnicianService[]
  approvedBy                 User?                          @relation("SemenTemplateApprovedBy", fields: [approvedById], references: [id])
  semenProvider              SemenProvider                  @relation(fields: [semenProviderId], references: [id])
  breedMixes                 SemenServiceTemplateBreedMix[]
  media                      SemenServiceTemplateMedia[]
  serviceInstances           ServiceInstance[]

  @@index([semenProviderId])
  @@index([animalType])
  @@index([approvalStatus, isActive])
}

model SemenServiceTemplateBreedMix {
  id         String               @id @default(cuid())
  templateId String
  breedId    String
  percentage Decimal              @db.Decimal(5, 2)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  breed      LivestockBreed       @relation(fields: [breedId], references: [id])
  template   SemenServiceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, breedId])
  @@index([breedId])
}

model SemenServiceTemplateMedia {
  id             String                 @id @default(cuid())
  templateId     String
  kind           SemenTemplateMediaKind
  uploadedFileId String?                @unique
  externalUrl    String?
  sortOrder      Int                    @default(0)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  template       SemenServiceTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  uploadedFile   UploadedFile?          @relation(fields: [uploadedFileId], references: [id])

  @@index([templateId])
  @@index([sortOrder])
}

/// Technician-published service / gig (pricing + animal scope).
model AiTechnicianService {
  id                           String                     @id @default(cuid())
  aiTechnicianId               String
  title                        String
  animalType                   AnimalType
  breedOrSemenType             String?
  description                  String?
  basePrice                    Decimal                    @db.Decimal(12, 2)
  visitFee                     Decimal?                   @db.Decimal(12, 2)
  emergencyFee                 Decimal?                   @db.Decimal(12, 2)
  repeatServicePolicy          String?
  followUpIncluded             Boolean                    @default(false)
  status                       AiTechnicianServiceStatus  @default(DRAFT)
  createdAt                    DateTime                   @default(now())
  updatedAt                    DateTime                   @updatedAt
  /// When set, locked semen copy/media come from this approved template (read API merges live template).
  semenServiceTemplateId       String?
  /// Technician listing: optional fixed offer price (mutually exclusive with `discountPercent`).
  offerPrice                   Decimal?                   @db.Decimal(12, 2)
  /// Technician listing: optional discount % (mutually exclusive with `offerPrice`).
  discountPercent              Decimal?                   @db.Decimal(5, 2)
  /// Technician can hide listing without changing admin `status`.
  isAvailable                  Boolean                    @default(true)
  technicianServiceNote        String?
  aiServiceRequests            AiServiceRequest[]
  aiTechnician                 AiTechnicianProfile        @relation(fields: [aiTechnicianId], references: [id], onDelete: Cascade)
  semenServiceTemplate         SemenServiceTemplate?      @relation(fields: [semenServiceTemplateId], references: [id], onDelete: Restrict)
  publishedFromServiceInstance ServiceInstance?           @relation("ServiceInstancePublishedListing")
  semenInventoryLots           TechnicianSemenInventory[]

  @@unique([aiTechnicianId, semenServiceTemplateId])
  @@index([aiTechnicianId])
  @@index([status])
  @@index([animalType])
  @@index([semenServiceTemplateId])
}

/// Per-batch / lot stock for a technician semen service (one public listing per template).
model TechnicianSemenInventory {
  id                    String              @id @default(cuid())
  aiTechnicianServiceId String
  currentQuantity       Int                 @default(0)
  reservedQuantity      Int                 @default(0)
  usedQuantity          Int                 @default(0)
  minStockAlert         Int?
  batchNumber           String?
  expiryDate            DateTime?
  sourceNote            String?
  storageNote           String?
  isActive              Boolean             @default(true)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  aiTechnicianService   AiTechnicianService @relation(fields: [aiTechnicianServiceId], references: [id], onDelete: Cascade)

  @@index([aiTechnicianServiceId])
  @@index([isActive])
}

/// Farmer-initiated AI service booking (module-native). Optional link to legacy `ServiceRequest` for integration.
model AiServiceRequest {
  id                     String                  @id @default(cuid())
  customerUserId         String
  technicianProfileId    String?
  serviceId              String?
  animalType             AnimalType
  breed                  String?
  animalAge              String?
  lastHeatDate           DateTime?
  heatSymptoms           String?
  previousAiHistory      String?
  healthIssueNote        String?
  district               String
  upazila                String
  unionOrArea            String?
  addressDetail          String?
  preferredTime          String?
  isEmergency            Boolean                 @default(false)
  status                 AiServiceRequestStatus  @default(PENDING)
  estimatedFee           Decimal?                @db.Decimal(12, 2)
  finalFee               Decimal?                @db.Decimal(12, 2)
  paymentStatus          AiPaymentStatus         @default(UNPAID)
  linkedServiceRequestId String?                 @unique
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  /// Optional note when technician declines (native AI requests).
  declineReason          String?
  aiServiceRecord        AiServiceRecord?
  customer               User                    @relation("AiServiceRequestCustomer", fields: [customerUserId], references: [id])
  linkedServiceRequest   ServiceRequest?         @relation(fields: [linkedServiceRequestId], references: [id])
  service                AiTechnicianService?    @relation(fields: [serviceId], references: [id])
  technicianProfile      AiTechnicianProfile?    @relation("AiServiceRequestTechnician", fields: [technicianProfileId], references: [id])
  aiTechnicianComplaints AiTechnicianComplaint[]
  aiTechnicianReview     AiTechnicianReview?

  @@index([customerUserId])
  @@index([technicianProfileId])
  @@index([status])
  @@index([createdAt])
}

/// Structured outcome for a completed (or in-progress) AI visit.
model AiServiceRecord {
  id                  String              @id @default(cuid())
  aiServiceRequestId  String              @unique
  technicianProfileId String
  customerUserId      String
  serviceDate         DateTime
  animalType          AnimalType
  breedOrSemenType    String?
  semenBatch          String?
  heatObservation     String?
  inseminationTime    DateTime?
  serviceNote         String?
  nextFollowUpDate    DateTime?
  pregnancyCheckDate  DateTime?
  totalFee            Decimal?            @db.Decimal(12, 2)
  paymentStatus       AiPaymentStatus     @default(UNPAID)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  aiServiceRequest    AiServiceRequest    @relation(fields: [aiServiceRequestId], references: [id], onDelete: Cascade)
  customer            User                @relation("AiServiceRecordCustomer", fields: [customerUserId], references: [id])
  technicianProfile   AiTechnicianProfile @relation(fields: [technicianProfileId], references: [id])

  @@index([technicianProfileId])
  @@index([customerUserId])
  @@index([serviceDate])
}

/// Farmer rating after a completed native AI visit (one per `AiServiceRequest`).
model AiTechnicianReview {
  id                  String                       @id @default(cuid())
  aiServiceRequestId  String                       @unique
  technicianProfileId String
  customerUserId      String
  rating              Int
  comment             String?
  visibility          AiTechnicianReviewVisibility @default(VISIBLE)
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
  aiServiceRequest    AiServiceRequest             @relation(fields: [aiServiceRequestId], references: [id], onDelete: Cascade)
  customer            User                         @relation("AiTechnicianReviewAuthor", fields: [customerUserId], references: [id])
  technicianProfile   AiTechnicianProfile          @relation("AiTechnicianModuleReview", fields: [technicianProfileId], references: [id], onDelete: Cascade)

  @@index([technicianProfileId])
  @@index([customerUserId])
  @@index([visibility])
}

/// Farmer complaint for AI technician module (native requests).
model AiTechnicianComplaint {
  id                  String                      @id @default(cuid())
  aiServiceRequestId  String?
  technicianProfileId String
  customerUserId      String
  category            String
  message             String
  status              AiTechnicianComplaintStatus @default(OPEN)
  adminNote           String?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  aiServiceRequest    AiServiceRequest?           @relation(fields: [aiServiceRequestId], references: [id])
  customer            User                        @relation("AiTechnicianComplaintAuthor", fields: [customerUserId], references: [id])
  technicianProfile   AiTechnicianProfile         @relation("AiTechnicianModuleComplaint", fields: [technicianProfileId], references: [id], onDelete: Cascade)

  @@index([technicianProfileId])
  @@index([customerUserId])
  @@index([status])
  @@index([aiServiceRequestId])
}

model AnimalProfile {
  id              String           @id @default(cuid())
  customerId      String
  name            String
  species         String
  breed           String?
  category        AnimalCategory   @default(OTHER)
  dateOfBirth     DateTime?
  sex             String?
  microchipOrTag  String?
  notes           String?
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  animalType      AnimalType?
  gender          Gender?
  weightKg        Decimal?         @db.Decimal(10, 3)
  photoUrl        String?
  pregnancyStatus PregnancyStatus?
  customer        CustomerProfile  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  prescriptions   Prescription[]
  serviceRequests ServiceRequest[]
  treatmentCases  TreatmentCase[]
  milkRecords     MilkRecord[]
  feedRecords     FeedRecord[]
  healthEvents    HealthEvent[]
  vaccineRecords  VaccineRecord[]
  farmTreatments           FarmTreatment[]
  fatteningBatchMemberships FatteningBatchAnimal[]
  weightRecords             WeightRecord[]

  @@index([customerId])
}

enum FatteningBatchStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum FatteningBatchGoalType {
  NORMAL
  QURBANI
}

model FatteningBatch {
  id         String               @id @default(cuid())
  customerId String
  farmId     String
  name       String
  goalType   FatteningBatchGoalType @default(NORMAL)
  goal       String?
  startDate  DateTime?            @db.Date
  targetDate DateTime?            @db.Date
  status     FatteningBatchStatus @default(DRAFT)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  customer       CustomerProfile      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  animals        FatteningBatchAnimal[]
  weightRecords  WeightRecord[]
  feedPlan       BatchFeedPlan?
  feedRecords    FeedRecord[]
  roi            FatteningBatchRoi?
  financeRecords FinanceRecord[]

  @@index([customerId, farmId, status])
  @@index([customerId, status, updatedAt])
}

enum BatchFeedPlanMode {
  NORMAL
  FATTENING
}

model BatchFeedPlan {
  id            String            @id @default(cuid())
  customerId    String
  batchId       String            @unique
  mode          BatchFeedPlanMode @default(FATTENING)
  dailyAmountKg Decimal?          @db.Decimal(10, 3)
  dailyCostBdt  Decimal?          @db.Decimal(12, 2)
  feedType      FeedType?
  unit          FeedUnit?         @default(KG)
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  customer      CustomerProfile   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  batch         FatteningBatch    @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

enum WeightRecordMethod {
  SCALE
  TAPE
  ESTIMATE
  OTHER
}

model WeightRecord {
  id         String             @id @default(cuid())
  customerId String
  animalId   String
  batchId    String
  weightKg   Decimal            @db.Decimal(10, 3)
  recordedAt DateTime
  recordedOn DateTime           @db.Date
  method     WeightRecordMethod @default(SCALE)
  note       String?
  photoUrl   String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  customer   CustomerProfile    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  animal     AnimalProfile      @relation(fields: [animalId], references: [id], onDelete: Cascade)
  batch      FatteningBatch     @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, animalId, recordedOn])
  @@index([customerId, batchId, recordedOn])
  @@index([animalId, batchId, recordedAt])
}

model FatteningBatchAnimal {
  id        String    @id @default(cuid())
  batchId   String
  animalId  String
  joinedAt  DateTime  @default(now())
  removedAt DateTime?

  batch  FatteningBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  animal AnimalProfile  @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@unique([batchId, animalId])
  @@index([batchId])
  @@index([animalId])
}

/// Per-batch ROI targets and manual cost overrides (Phase 4).
model FatteningBatchRoi {
  id               String   @id @default(cuid())
  customerId       String
  batchId          String   @unique
  purchaseCostBdt  Decimal? @db.Decimal(12, 2)
  projectedSaleBdt Decimal? @db.Decimal(12, 2)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  customer         CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  batch            FatteningBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model ServiceRequest {
  id                     String                        @id @default(cuid())
  customerId             String
  animalId               String
  /// Legacy link — prefer `villageId` for new records.
  areaId                 String?
  serviceCategoryId      String
  assignedDoctorId       String?
  status                 ServiceRequestStatus          @default(PENDING)
  urgency                String?
  /// Stored as `symptoms` in PostgreSQL.
  problemOrSymptom       String?                       @map("symptoms")
  /// Stored as `preferredWindow` in PostgreSQL.
  preferredTime          String?                       @map("preferredWindow")
  /// Stored as `locationNotes` in PostgreSQL.
  locationText           String?                       @map("locationNotes")
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt
  completedAt            DateTime?
  /// Stored as `assignedAiTechnicianId` in PostgreSQL (historic column name).
  assignedTechnicianId   String?                       @map("assignedAiTechnicianId")
  assignedAt             DateTime?
  cancelledAt            DateTime?
  emergencyNotes         String?
  isEmergency            Boolean                       @default(false)
  /// Stored as `requestType` in PostgreSQL (historic column name).
  serviceType            ServiceRequestType            @default(DOCTOR_HOME_VISIT) @map("requestType")
  scheduledEnd           DateTime?
  scheduledStart         DateTime?
  startedAt              DateTime?
  submittedAt            DateTime                      @default(now())
  villageId              String?
  description            String?
  cancelReason           String?
  adminNote              String?
  leadId                 String?                       @unique
  /// P3 — formal priority (maps from isEmergency / urgency).
  priority               RequestPriority               @default(NORMAL)
  aiAssistantSessions    AiAssistantSession[]
  linkedAiServiceRequest AiServiceRequest?
  billingRecords         BillingRecord[]
  complaints             Complaint[]
  paymentRecords         PaymentRecord[]
  prescriptions          Prescription[]
  reviews                Review[]
  animal                 AnimalProfile                 @relation(fields: [animalId], references: [id])
  area                   Area?                         @relation(fields: [areaId], references: [id], onDelete: Restrict)
  assignedTechnician     AiTechnicianProfile?          @relation(fields: [assignedTechnicianId], references: [id])
  assignedDoctor         DoctorProfile?                @relation(fields: [assignedDoctorId], references: [id])
  customer               CustomerProfile               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  crmLead                Lead?                         @relation("LeadServiceRequest", fields: [leadId], references: [id])
  serviceCategory        ServiceCategory               @relation(fields: [serviceCategoryId], references: [id])
  village                Village?                      @relation(fields: [villageId], references: [id], onDelete: Restrict)
  timelineEvents         ServiceRequestTimelineEvent[]
  treatmentConsultations TreatmentConsultation[]
  treatmentFollowups     TreatmentFollowup[]
  treatmentNotes         TreatmentNote[]
  treatmentCases         TreatmentCase[]
  treatmentWorkflow      TreatmentWorkflow?
  voiceSessions          VoiceSession[]

  @@index([status])
  @@index([priority])
  @@index([customerId])
  @@index([animalId])
  @@index([assignedDoctorId, status])
  @@index([assignedTechnicianId, status])
  @@index([serviceType, status])
  @@index([areaId, serviceCategoryId])
  @@index([villageId])
}

/// Former `TreatmentRecord` table — mapped to preserve existing rows.
model TreatmentCase {
  id               String               @id @default(cuid())
  serviceRequestId String
  doctorId         String?
  animalId         String
  chiefComplaint   String?
  diagnosis        String?
  procedures       String?
  followUpNotes    String?
  recordedAt       DateTime             @default(now())
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  aiTechnicianId   String?
  followUpDate     DateTime?
  symptoms         String?
  treatmentNotes   String?
  status           TreatmentCaseStatus  @default(DRAFT)
  billingRecords   BillingRecord[]
  aiTechnician     AiTechnicianProfile? @relation(fields: [aiTechnicianId], references: [id], onDelete: Restrict)
  animal           AnimalProfile        @relation(fields: [animalId], references: [id])
  doctor           DoctorProfile?       @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  serviceRequest   ServiceRequest       @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  workflow         TreatmentWorkflow?

  @@index([serviceRequestId])
  @@index([doctorId])
  @@index([aiTechnicianId])
  @@index([status])
  @@map("TreatmentRecord")
}

/// P5 — treatment workflow state machine (one per service request).
model TreatmentWorkflow {
  id               String                  @id @default(cuid())
  serviceRequestId String                  @unique
  doctorId         String
  status           TreatmentWorkflowStatus @default(ASSIGNED)
  treatmentCaseId  String?                 @unique
  closedAt         DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  consultations    TreatmentConsultation[]
  followups        TreatmentFollowup[]
  notes            TreatmentNote[]
  doctor           DoctorProfile           @relation(fields: [doctorId], references: [id])
  serviceRequest   ServiceRequest          @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  treatmentCase    TreatmentCase?          @relation(fields: [treatmentCaseId], references: [id])

  @@index([doctorId])
  @@index([status])
}

/// P5 — consultation record (observations, attachment refs).
model TreatmentConsultation {
  id               String            @id @default(cuid())
  serviceRequestId String
  workflowId       String
  doctorId         String
  observations     String?
  diagnosisSummary String?
  attachmentRefs   Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  doctor           DoctorProfile     @relation(fields: [doctorId], references: [id])
  serviceRequest   ServiceRequest    @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  workflow         TreatmentWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([serviceRequestId])
  @@index([workflowId])
  @@index([doctorId])
}

/// P5 — followup scheduling (no notification dispatch).
model TreatmentFollowup {
  id               String                  @id @default(cuid())
  serviceRequestId String
  workflowId       String
  doctorId         String
  scheduledAt      DateTime
  reminderNote     String?
  status           TreatmentFollowupStatus @default(PENDING)
  completedAt      DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  doctor           DoctorProfile           @relation(fields: [doctorId], references: [id])
  serviceRequest   ServiceRequest          @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  workflow         TreatmentWorkflow       @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([serviceRequestId])
  @@index([workflowId])
  @@index([doctorId])
  @@index([status])
}

/// P5 — clinical notes (private / shared / audit).
model TreatmentNote {
  id               String            @id @default(cuid())
  serviceRequestId String
  workflowId       String
  authorDoctorId   String
  noteType         TreatmentNoteType
  content          String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  author           DoctorProfile     @relation("TreatmentNoteAuthor", fields: [authorDoctorId], references: [id])
  serviceRequest   ServiceRequest    @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  workflow         TreatmentWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([serviceRequestId])
  @@index([workflowId])
  @@index([authorDoctorId])
  @@index([noteType])
}

/// P6 — AI assistant session (farmer chat, no autonomous diagnosis).
model AiAssistantSession {
  id             String               @id @default(cuid())
  userId         String
  caseId         String?
  locale         String               @default("bn")
  status         AiAssistantStatus    @default(ACTIVE)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  memories       AiAssistantMemory[]
  messages       AiAssistantMessage[]
  serviceRequest ServiceRequest?      @relation(fields: [caseId], references: [id])
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  escalations    AiEscalationRecord[]
  auditLogs      AiSafetyAuditLog[]
  triageRecords  AiTriageRecord[]

  @@index([userId])
  @@index([caseId])
  @@index([status])
}

model AiAssistantMessage {
  id         String             @id @default(cuid())
  sessionId  String
  role       AiMessageRole
  content    String
  locale     String?
  inputJson  Json?
  outputJson Json?
  refused    Boolean            @default(false)
  createdAt  DateTime           @default(now())
  session    AiAssistantSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

/// P6 — explicit memory (no diagnosis / hidden decision storage).
model AiAssistantMemory {
  id        String              @id @default(cuid())
  sessionId String?
  userId    String
  kind      AiMemoryKind
  key       String
  valueJson Json
  expiresAt DateTime?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  session   AiAssistantSession? @relation(fields: [sessionId], references: [id])

  @@unique([userId, kind, key])
  @@index([userId])
  @@index([expiresAt])
}

model AiTriageRecord {
  id                 String              @id @default(cuid())
  sessionId          String?
  userId             String
  caseId             String?
  riskBucket         AiRiskBucket
  urgencyLevel       Int
  recommendation     String
  escalationRequired Boolean             @default(false)
  symptomsJson       Json?
  mediaMetadataJson  Json?
  createdAt          DateTime            @default(now())
  session            AiAssistantSession? @relation(fields: [sessionId], references: [id])

  @@index([userId])
  @@index([caseId])
  @@index([riskBucket])
}

model AiEscalationRecord {
  id          String              @id @default(cuid())
  sessionId   String?
  userId      String
  caseId      String?
  reason      AiEscalationReason
  status      AiEscalationStatus  @default(PENDING_REVIEW)
  handoffNote String?
  flaggedAt   DateTime            @default(now())
  resolvedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  session     AiAssistantSession? @relation(fields: [sessionId], references: [id])

  @@index([userId])
  @@index([caseId])
  @@index([status])
}

model AiSafetyAuditLog {
  id         String              @id @default(cuid())
  sessionId  String?
  userId     String?
  action     String
  detailJson Json?
  createdAt  DateTime            @default(now())
  session    AiAssistantSession? @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([userId])
  @@index([action])
}

/// Global AI governance — LLM kill switch (singleton row id = "global").
model AiGovernanceState {
  id              String   @id @default("global")
  llmDisabled     Boolean  @default(false)
  version         BigInt   @default(1)
  updatedAt       DateTime @updatedAt
  updatedByUserId String?
  updatedByRole   String?
  reason          String?
  source          String   @default("startup_sync")
  history         AiGovernanceStateHistory[]
}

/// Append-only audit trail for AI governance changes.
model AiGovernanceStateHistory {
  id                  String            @id @default(cuid())
  stateId             String            @default("global")
  llmDisabled         Boolean
  previousLlmDisabled Boolean
  version             BigInt
  changeKind          String            @default("global")
  scopeType           String?
  scopeId             String?
  disabled            Boolean?
  previousDisabled    Boolean?
  actorId             String?
  actorRole           String?
  reason              String?
  source              String
  requestId           String?
  correlationId       String?
  rollbackOfId        String?
  createdAt           DateTime          @default(now())
  state               AiGovernanceState @relation(fields: [stateId], references: [id], onDelete: Cascade)

  @@index([stateId, createdAt])
  @@index([actorId, createdAt])
  @@index([changeKind, createdAt])
}

/// Per-feature / per-provider kill switch scopes (PostgreSQL source of truth).
model AiGovernanceScope {
  scopeType       String
  scopeId         String
  disabled        Boolean  @default(false)
  version         BigInt   @default(1)
  updatedAt       DateTime @updatedAt
  updatedByUserId String?
  updatedByRole   String?
  reason          String?
  source          String   @default("startup_sync")

  @@id([scopeType, scopeId])
}

/// P7 — Bangla voice assistant session (transcript metadata; no raw audio by default).
model VoiceSession {
  id             String                 @id @default(cuid())
  userId         String
  aiSessionId    String?
  caseId         String?
  locale         String                 @default("bn")
  bandwidthMode  VoiceBandwidthMode     @default(FULL)
  status         VoiceSessionStatus     @default(ACTIVE)
  interruptedAt  DateTime?
  retryCount     Int                    @default(0)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  navEvents      VoiceNavigationEvent[]
  serviceRequest ServiceRequest?        @relation(fields: [caseId], references: [id])
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transcripts    VoiceTranscript[]

  @@index([userId])
  @@index([caseId])
  @@index([status])
}

model VoiceTranscript {
  id             String       @id @default(cuid())
  sessionId      String
  normalizedText String
  rawHint        String?
  confidence     Float
  sttMode        VoiceSttMode
  partial        Boolean      @default(false)
  locale         String       @default("bn")
  durationMs     Int?
  audioSizeBytes Int?
  codec          String?
  retainAudio    Boolean      @default(false)
  retrySuggested Boolean      @default(false)
  createdAt      DateTime     @default(now())
  session        VoiceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model VoiceNavigationEvent {
  id           String       @id @default(cuid())
  sessionId    String
  utterance    String
  aliasMatched String?
  action       String
  success      Boolean      @default(true)
  createdAt    DateTime     @default(now())
  session      VoiceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([action])
}

/// P8 — Offline sync session (connectivity + queue counters).
model OfflineSyncSession {
  id                   String                  @id @default(cuid())
  userId               String
  deviceId             String?
  connectivityMode     OfflineConnectivityMode @default(ONLINE)
  manualOverride       Boolean                 @default(false)
  lastSyncAt           DateTime?
  lastClientSnapshotAt DateTime?
  pendingCount         Int                     @default(0)
  deadCount            Int                     @default(0)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  items                OfflineSyncItem[]
  user                 User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
}

/// P8 — Idempotent offline sync queue item.
model OfflineSyncItem {
  id               String                  @id @default(cuid())
  userId           String
  sessionId        String?
  idempotencyKey   String
  entityType       OfflineSyncEntityType
  operation        OfflineSyncOperation    @default(UPSERT)
  payloadHash      String
  payloadJson      Json
  conflictStrategy OfflineConflictStrategy
  status           OfflineSyncItemStatus   @default(PENDING)
  attemptCount     Int                     @default(0)
  maxAttempts      Int                     @default(5)
  lastError        String?
  lastAttemptAt    DateTime?
  nextRetryAt      DateTime?
  clientSequence   Int
  batchId          String?
  serverEntityId   String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  conflicts        OfflineConflictRecord[]
  leadDraft        OfflineLeadDraft[]
  session          OfflineSyncSession?     @relation(fields: [sessionId], references: [id])
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, idempotencyKey])
  @@index([userId, status])
  @@index([userId, clientSequence])
  @@index([nextRetryAt])
  @@index([sessionId])
}

/// P8 — Offline lead draft (no assignment until online sync).
model OfflineLeadDraft {
  id                String                 @id @default(cuid())
  userId            String
  syncItemId        String?
  clientLeadId      String
  phone             String
  name              String?
  concern           String?
  animalType        String?
  villageId         String?
  mediaMetadataJson Json?
  status            OfflineLeadQueueStatus @default(QUEUED)
  serverLeadId      String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  serverLead        Lead?                  @relation(fields: [serverLeadId], references: [id])
  syncItem          OfflineSyncItem?       @relation(fields: [syncItemId], references: [id])
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clientLeadId])
  @@index([userId, status])
  @@index([syncItemId])
}

/// P8 — Conflict audit (no silent overwrite).
model OfflineConflictRecord {
  id               String                  @id @default(cuid())
  userId           String
  syncItemId       String
  entityType       OfflineSyncEntityType
  entityId         String?
  resolution       OfflineConflictStrategy
  serverVersion    String?
  clientVersion    String?
  mergePayloadJson Json?
  resolvedAt       DateTime?
  createdAt        DateTime                @default(now())
  syncItem         OfflineSyncItem         @relation(fields: [syncItemId], references: [id], onDelete: Cascade)
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([syncItemId])
}

/// P3 — append-only audit trail for service requests.
model ServiceRequestTimelineEvent {
