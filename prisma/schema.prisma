  createdAt         DateTime                     @default(now())
  customer          CustomerProfile              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  item              InventoryItem                @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  feedRecord        FeedRecord?                  @relation("FeedInventoryTransaction")

  @@unique([customerId, idempotencyKey])
  @@index([inventoryItemId, recordedAt])
  @@index([customerId, farmRef, inventoryType])
  @@index([sourceType, sourceId])
}

