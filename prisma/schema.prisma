model ServiceInstancePublishLog {
  id                         String                       @id @default(cuid())
  serviceInstanceId          String
  action                     ServiceInstancePublishAction
  actorUserId                String
  previousPublishedServiceId String?
  newPublishedServiceId      String?
  payloadSnapshotJson        Json?
  createdAt                  DateTime                     @default(now())
  actor                      User                         @relation(fields: [actorUserId], references: [id])
  serviceInstance            ServiceInstance              @relation(fields: [serviceInstanceId], references: [id], onDelete: Cascade)

  @@index([serviceInstanceId, createdAt])
  @@index([actorUserId])
}

model ServiceInstanceAuditEvent {
  id                String                     @id @default(cuid())
  serviceInstanceId String
  action            ServiceInstanceAuditAction
  actorUserId       String?
  ipAddress         String?
  userAgent         String?
  detailsJson       Json?
  createdAt         DateTime                   @default(now())
  actor             User?                      @relation(fields: [actorUserId], references: [id])
  serviceInstance   ServiceInstance            @relation(fields: [serviceInstanceId], references: [id], onDelete: Cascade)

  @@index([serviceInstanceId, createdAt])
  @@index([actorUserId])
}

/// Phase 1 identity — login, OTP, permission, and session audit (additive).
model AuthAuditEvent {
  id        String          @id @default(cuid())
  action    AuthAuditAction
  userId    String?
  role      UserRole?
  channel   String
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime        @default(now())
  user      User?           @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  valueJson Json
  updatedAt DateTime @updatedAt
}

