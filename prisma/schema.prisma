/// Enterprise: worker submission of a semen (main) template for admin review → publish → `AiTechnicianService`.
model ServiceInstance {
  id                             String                      @id @default(cuid())
  semenServiceTemplateId         String
  aiTechnicianProfileId          String
  status                         ServiceInstanceStatus       @default(DRAFT)
  schemaVersion                  Int                         @default(1)
  payloadJson                    Json                        @default("{}")
  lockedSnapshotJson             Json?
  validationResultJson           Json?
  duplicateOfId                  String?
  payloadFingerprint             String?
  correctionNote                 String?
  adminInternalNote              String?
  submittedAt                    DateTime?
  publishedAt                    DateTime?
  archivedAt                     DateTime?
  lastReviewedById               String?
  publishedAiTechnicianServiceId String?                     @unique
  deploymentBranch               String?                     @default("main")
  tenantId                       String?
  deletedAt                      DateTime?
  version                        Int                         @default(0)
  createdAt                      DateTime                    @default(now())
  updatedAt                      DateTime                    @updatedAt
  aiTechnicianProfile            AiTechnicianProfile         @relation(fields: [aiTechnicianProfileId], references: [id], onDelete: Cascade)
  duplicateOf                    ServiceInstance?            @relation("ServiceInstanceDuplicateOf", fields: [duplicateOfId], references: [id])
  duplicates                     ServiceInstance[]           @relation("ServiceInstanceDuplicateOf")
  lastReviewedBy                 User?                       @relation("ServiceInstanceLastReviewedBy", fields: [lastReviewedById], references: [id])
  publishedAiTechnicianService   AiTechnicianService?        @relation("ServiceInstancePublishedListing", fields: [publishedAiTechnicianServiceId], references: [id])
  semenServiceTemplate           SemenServiceTemplate        @relation(fields: [semenServiceTemplateId], references: [id])
  auditEvents                    ServiceInstanceAuditEvent[]
  media                          ServiceInstanceMedia[]
  publishLogs                    ServiceInstancePublishLog[]
  reviews                        ServiceInstanceReview[]
  statusLogs                     ServiceInstanceStatusLog[]

  @@index([status, submittedAt])
  @@index([tenantId, deploymentBranch])
  @@index([deploymentBranch])
  @@index([deletedAt])
  @@index([payloadFingerprint])
  @@index([semenServiceTemplateId])
  @@index([aiTechnicianProfileId, semenServiceTemplateId], map: "ServiceInstance_aiTechnicianProfileId_semenServiceTemplateId_id")
}

