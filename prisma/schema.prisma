/// Technician-published service / gig (pricing + animal scope).
model AiTechnicianService {
  id                           String                     @id @default(cuid())
  aiTechnicianId               String
  title                        String
  animalType                   AnimalType
  breedOrSemenType             String?
  description                  String?
  basePrice                    Decimal                    @db.Decimal(12, 2)
  visitFee                     Decimal?                   @db.Decimal(12, 2)
  emergencyFee                 Decimal?                   @db.Decimal(12, 2)
  repeatServicePolicy          String?
  followUpIncluded             Boolean                    @default(false)
  status                       AiTechnicianServiceStatus  @default(DRAFT)
  createdAt                    DateTime                   @default(now())
  updatedAt                    DateTime                   @updatedAt
  /// When set, locked semen copy/media come from this approved template (read API merges live template).
  semenServiceTemplateId       String?
  /// Technician listing: optional fixed offer price (mutually exclusive with `discountPercent`).
  offerPrice                   Decimal?                   @db.Decimal(12, 2)
  /// Technician listing: optional discount % (mutually exclusive with `offerPrice`).
  discountPercent              Decimal?                   @db.Decimal(5, 2)
  /// Technician can hide listing without changing admin `status`.
  isAvailable                  Boolean                    @default(true)
  technicianServiceNote        String?
  aiServiceRequests            AiServiceRequest[]
