  semenServiceTemplate         SemenServiceTemplate?      @relation(fields: [semenServiceTemplateId], references: [id], onDelete: Restrict)
  publishedFromServiceInstance ServiceInstance?           @relation("ServiceInstancePublishedListing")
  semenInventoryLots           TechnicianSemenInventory[]

  @@unique([aiTechnicianId, semenServiceTemplateId])
  @@index([aiTechnicianId])
  @@index([status])
  @@index([animalType])
  @@index([semenServiceTemplateId])
}

/// Per-batch / lot stock for a technician semen service (one public listing per template).
model TechnicianSemenInventory {
  id                    String              @id @default(cuid())
  aiTechnicianServiceId String
  currentQuantity       Int                 @default(0)
  reservedQuantity      Int                 @default(0)
  usedQuantity          Int                 @default(0)
  minStockAlert         Int?
  batchNumber           String?
  expiryDate            DateTime?
  sourceNote            String?
  storageNote           String?
  isActive              Boolean             @default(true)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  aiTechnicianService   AiTechnicianService @relation(fields: [aiTechnicianServiceId], references: [id], onDelete: Cascade)

  @@index([aiTechnicianServiceId])
  @@index([isActive])
}

/// Farmer-initiated AI service booking (module-native). Optional link to legacy `ServiceRequest` for integration.
model AiServiceRequest {
  id                     String                  @id @default(cuid())
  customerUserId         String
  technicianProfileId    String?
  serviceId              String?
  animalType             AnimalType
  breed                  String?
  animalAge              String?
  lastHeatDate           DateTime?
  heatSymptoms           String?
  previousAiHistory      String?
  healthIssueNote        String?
  district               String
  upazila                String
  unionOrArea            String?
  addressDetail          String?
  preferredTime          String?
  isEmergency            Boolean                 @default(false)
  status                 AiServiceRequestStatus  @default(PENDING)
  estimatedFee           Decimal?                @db.Decimal(12, 2)
  finalFee               Decimal?                @db.Decimal(12, 2)
