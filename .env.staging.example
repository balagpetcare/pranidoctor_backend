# Staging — copy to .env on staging host
NODE_ENV=staging
PORT=3000

DATABASE_URL=postgresql://USER:PASSWORD@postgres:5432/pranidoctor_staging?sslmode=require

REDIS_ENABLED=true
REDIS_URL=redis://redis:6379

STORAGE_DRIVER=s3
S3_ENDPOINT=https://staging-storage.example.com
S3_ACCESS_KEY=REPLACE_ME
S3_SECRET_KEY=REPLACE_ME
S3_BUCKET=pranidoctor-staging

ADMIN_JWT_SECRET=REPLACE_WITH_openssl_rand_base64_32
MOBILE_JWT_SECRET=REPLACE_WITH_openssl_rand_base64_32
DOCTOR_JWT_SECRET=REPLACE_WITH_openssl_rand_base64_32
TECHNICIAN_JWT_SECRET=REPLACE_WITH_openssl_rand_base64_32
MOBILE_REFRESH_SECRET=REPLACE_WITH_openssl_rand_base64_32
REFRESH_TOKEN_PEPPER=REPLACE_WITH_openssl_rand_base64_32

OTP_MODE=live
LOG_LEVEL=info
LOG_FORMAT=json
CORS_ORIGINS=https://staging-admin.example.com

API_DOCS_KEY=REPLACE_STAGING_DOCS_KEY
METRICS_ENABLED=true
METRICS_TOKEN=REPLACE_METRICS_TOKEN
ERROR_TRACKING_WEBHOOK_URL=
SENTRY_ENABLED=true
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
APP_ENV=staging
