# Development — copy to .env (never commit .env)
NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://pranidoctor:pranidoctor_dev_password@localhost:5432/pranidoctor

REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379

STORAGE_ENABLED=true
STORAGE_DRIVER=minio
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY=REPLACE_MINIO_ACCESS_KEY
S3_SECRET_KEY=REPLACE_MINIO_SECRET_KEY
S3_BUCKET=pranidoctor-dev

# Dev-only JWT placeholders (min 32 chars; CHANGE_ME allowed in development)
ADMIN_JWT_SECRET=dev_admin_jwt_secret_minimum_32_characters
MOBILE_JWT_SECRET=dev_mobile_jwt_secret_minimum_32_chars
DOCTOR_JWT_SECRET=dev_doctor_jwt_secret_minimum_32_chars
TECHNICIAN_JWT_SECRET=dev_technician_jwt_secret_min_32
MOBILE_REFRESH_SECRET=dev_mobile_refresh_secret_min_32_chars

OTP_MODE=dev
LOG_LEVEL=debug
LOG_FORMAT=pretty
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# OpenAPI docs open in development (no API_DOCS_KEY)
METRICS_ENABLED=true
