{
  "name": "pranidoctor-backend",
  "version": "1.0.0",
  "description": "Prani Doctor Backend API - Express.js modular monolith",
  "main": "dist/server.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run typecheck && tsc -p tsconfig.build.json",
    "typecheck:legacy": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/server.js",
    "worker": "tsx src/worker.ts",
    "worker:dev": "tsx watch src/worker.ts",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:admin": "tsx prisma/seed-admin.ts",
    "db:seed:demo": "tsx prisma/seed-demo.ts",
    "db:seed:reset-demo": "tsx prisma/seed-demo-reset.ts",
    "seed:user": "tsx scripts/dev/seed-user-data.ts",
    "seed:user-app": "tsx scripts/seed/user_app_seed.ts",
    "location:reset": "tsx scripts/reset-location-data.ts",
    "seed:location": "tsx scripts/import-location-sheet.ts",
    "seed:reset-location": "tsx prisma/seed-location.ts reset",
    "seed:full-location": "tsx prisma/seed-location.ts full",
    "legacy:fix-imports": "node scripts/fix-legacy-imports.mjs",
    "env:validate": "tsx scripts/env-validate.ts",
    "foundation:verify": "tsx scripts/foundation-verify.ts",
    "phase2:auth-verify": "tsx scripts/phase2-auth-verify.ts",
    "area:seed": "tsx scripts/area-seed.ts",
    "area:verify": "tsx scripts/area-verify.ts",
    "treatment:verify": "tsx scripts/treatment-verify.ts",
    "ai:verify": "tsx scripts/ai-verify.ts",
    "voice:verify": "tsx scripts/voice-verify.ts",
    "offline:verify": "tsx scripts/offline-verify.ts",
    "docker:up": "docker compose up -d postgres redis minio",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "wait:services": "tsx scripts/wait-for-services.ts",
    "validate:startup": "tsx scripts/validate-startup.ts",
    "validate:mobile-modules": "tsx scripts/validate-mobile-modules.ts",
    "ci:validate": "npm run validate:mobile-modules && npx eslint src/shared/config/mobile-profile-startup.ts src/api/health/mobile-health.service.ts --max-warnings 0",
    "verify:runtime": "tsx scripts/runtime-verification.ts",
    "openapi:generate": "node scripts/generate-openapi.mjs",
    "e2e:freeze": "tsx scripts/e2e-freeze-verify.ts",
    "p1:auth-compat": "tsx scripts/p1-auth-compat-verify.ts",
    "p1:03-verify": "tsx scripts/p1-03-verify.ts",
    "p1:06-verify": "tsx scripts/p1-06-verify.ts",
    "p1:04-05-verify": "tsx scripts/p1-04-05-verify.ts",
    "p1:07-08-verify": "tsx scripts/p1-verify.ts",
    "p1:09-verify": "tsx scripts/p1-09-verify.ts",
    "p1:11-verify": "tsx scripts/p1-11-verify.ts",
    "p1:10-verify": "tsx scripts/p1-10-verify.ts",
    "p1:12-verify": "tsx scripts/p1-12-verify.ts",
    "p1:full-verify": "npm run build && npm run openapi:generate && npm run p1:12-verify && npm run e2e:freeze",
    "p2:verify": "tsx scripts/p2-verify.ts",
    "p2:full-verify": "npm run build && npm run openapi:generate && npm run p2:verify && npm run e2e:freeze",
    "p3:verify": "tsx scripts/p3-verify.ts",
    "p3:full-verify": "npm run build && npm run openapi:generate && npm run p3:verify && npm run e2e:freeze",
    "p1:verify": "tsx scripts/p1-verify.ts",
    "env:resolve": "node scripts/resolve-env.mjs",
    "bootstrap": "bash scripts/bootstrap.sh",
    "predev": "tsx scripts/wait-for-services.ts",
    "dev:no-docker": "tsx watch src/server.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1051.0",
    "@aws-sdk/s3-request-presigner": "^3.1051.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.34.0",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.0",
    "jose": "^6.2.3",
    "multer": "^2.1.1",
    "nanoid": "^5.1.5",
    "next": "file:./shims/next-compat",
    "pg": "^8.21.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.15.0",
    "@types/pg": "^8.20.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "dotenv": "^17.2.1",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-import": "^2.31.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.0",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.5"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
