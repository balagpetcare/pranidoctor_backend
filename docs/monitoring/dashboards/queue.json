{
  "title": "Prani Doctor — Queue",
  "uid": "pranidoctor-queue",
  "tags": ["pranidoctor", "queue"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Queue subsystem up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "pranidoctor_queue_up" }]
    },
    {
      "id": 2,
      "title": "Waiting jobs",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by (queue) (pranidoctor_queue_waiting_jobs)",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Active jobs",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "targets": [
        {
          "expr": "sum by (queue) (pranidoctor_queue_active_jobs)",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Failed job backlog",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "targets": [
        {
          "expr": "sum by (queue) (pranidoctor_queue_failed_jobs)",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Job completion rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(pranidoctor_queue_jobs_total[5m]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Job duration p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(pranidoctor_queue_job_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    }
  ]
}
