{
  "title": "Prani Doctor — API Overview",
  "uid": "pranidoctor-api-overview",
  "tags": ["pranidoctor", "api"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Request rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(pranidoctor_http_requests_total[5m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 2,
      "title": "5xx error rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(pranidoctor_http_requests_total{status_class=\"5xx\"}[5m])) / sum(rate(pranidoctor_http_requests_total[5m]))",
          "legendFormat": "5xx ratio"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP p95 latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(pranidoctor_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 4,
      "title": "Top routes by volume",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "topk(10, sum by (route) (rate(pranidoctor_http_requests_total[5m])))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Status codes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum by (status_code) (rate(pranidoctor_http_status_total[5m]))",
          "legendFormat": "{{status_code}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "API ready",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 24 },
      "targets": [{ "expr": "pranidoctor_ready" }]
    }
  ]
}
