{
  "title": "Prani Doctor — AI Ops",
  "uid": "pranidoctor-ai-ops",
  "tags": ["pranidoctor", "ai"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "AI requests by status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (status) (rate(ai_requests_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "AI requests by provider",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (provider) (rate(ai_requests_total[5m]))",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "AI p95 latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ai_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 4,
      "title": "Fallback rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(ai_requests_total{provider=\"rules-based\"}[5m])) / sum(rate(ai_requests_total[5m]))",
          "legendFormat": "fallback ratio"
        }
      ]
    },
    {
      "id": 5,
      "title": "LLM kill switch",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "targets": [{ "expr": "ai_llm_disabled" }]
    },
    {
      "id": 6,
      "title": "Hourly AI cost (USD)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 16 },
      "targets": [
        {
          "expr": "rate(ai_cost_usd_total[1h])",
          "legendFormat": "cost/h"
        }
      ]
    }
  ]
}
