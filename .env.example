# ============================================
# Application
# See also: .env.development.example | .env.staging.example | .env.production.example
# ============================================
NODE_ENV=development
PORT=3000
APP_NAME=pranidoctor-api
APP_VERSION=1.0.0

# ============================================
# Database (PostgreSQL) — EXTERNAL FIRST
# Set DATABASE_URL to your local/cloud Postgres instance.
# Component vars (DB_*) are used only when DATABASE_URL is unset.
# dotenv does NOT expand ${VAR}.
# ============================================
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/pranidoctor

# Optional components (fallback if DATABASE_URL unset)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=pranidoctor
# DB_USER=pranidoctor
# DB_PASSWORD=your_password

DB_POOL_MIN=2
DB_POOL_MAX=10

# ============================================
# Redis — OPTIONAL IN DEVELOPMENT
# Set REDIS_ENABLED=false to run without Redis (no OTP/sessions/queues).
# ============================================
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379
REDIS_PREFIX=pd:

# AI governance — persisted LLM kill switch (PostgreSQL + Redis)
AI_KILL_SWITCH_PERSISTENCE_ENABLED=true
# Emergency: force rules-only on startup (does not persist; use admin when available)
# AI_LLM_DISABLED=true
# AI_GOVERNANCE_POLL_INTERVAL_MS=45000

# ============================================
# Object storage — PLUGGABLE
# STORAGE_DRIVER: disabled | local | minio | s3
# STORAGE_ENABLED=false disables uploads (like REDIS_ENABLED for cache).
# ============================================
STORAGE_ENABLED=true
STORAGE_DRIVER=minio
LOCAL_STORAGE_PATH=./.local-storage

# Remote S3 / MinIO (when STORAGE_DRIVER=minio or s3)
# Must match docker-compose minio-init bucket (default: pranidoctor-dev)
MINIO_HOST=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pranidoctor-dev
MINIO_PUBLIC_URL=http://127.0.0.1:9000
# Resolved into S3_ENDPOINT at startup when unset:
# MINIO_URL=http://127.0.0.1:9000
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=pranidoctor-dev
S3_ACCESS_KEY=REPLACE_MINIO_ACCESS_KEY
S3_SECRET_KEY=REPLACE_MINIO_SECRET_KEY
S3_FORCE_PATH_STYLE=true
S3_SIGNED_URL_EXPIRY_SECONDS=300

# ============================================
# JWT Secrets (openssl rand -base64 32)
# ============================================
ADMIN_JWT_SECRET=CHANGE_ME_admin_jwt_secret_at_least_32_chars
MOBILE_JWT_SECRET=CHANGE_ME_mobile_jwt_secret_at_least_32_chars
DOCTOR_JWT_SECRET=CHANGE_ME_doctor_jwt_secret_at_least_32_chars
TECHNICIAN_JWT_SECRET=CHANGE_ME_tech_jwt_secret_at_least_32_chars
MOBILE_REFRESH_SECRET=CHANGE_ME_refresh_secret_at_least_32_chars

# ============================================
# OTP
# ============================================
OTP_LENGTH=6
OTP_EXPIRY_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_MAX_SENDS_PER_HOUR=5

# ============================================
# Mobile legal / privacy (Setting: mobile.legal.config overrides)
# ============================================
MOBILE_PRIVACY_POLICY_URL=https://pranidoctor.com/privacy
MOBILE_TERMS_OF_SERVICE_URL=https://pranidoctor.com/terms
# When true, protected mobile APIs return LEGAL_CONSENT_REQUIRED until privacy accepted
MOBILE_ENFORCE_PRIVACY_CONSENT=false

# ============================================
# Logging / CORS / Rate limit
# ============================================
LOG_LEVEL=info
LOG_FORMAT=pretty
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Upload limits
# ============================================
UPLOAD_MAX_IMAGE_MB=5
UPLOAD_MAX_DOCUMENT_MB=10
UPLOAD_MAX_VIDEO_MB=80

# ============================================
# Phase 6 — Observability & docs
# ============================================
# METRICS_ENABLED=true
# METRICS_TOKEN=replace-for-production-metrics-auth
# HTTP_METRICS_ENABLED=true          # false disables HTTP request/latency counters
# DB_QUERY_METRICS_ENABLED=true      # false disables Prisma query metrics (prod overhead)
# DB_SLOW_QUERY_MS=200               # Slow query log + pranidoctor_db_slow_queries_total threshold
# ESCALATION_MONITORING_ENABLED=true # Business ops SLA checks (ServiceRequest, support, AI)
# ESCALATION_CHECK_INTERVAL_MS=300000
# OPS_EMERGENCY_UNASSIGNED_MINUTES=15
# OPS_DOCTOR_ACCEPT_EMERGENCY_MINUTES=15
# OPS_DOCTOR_ACCEPT_HIGH_MINUTES=60
# OPS_DOCTOR_ACCEPT_NORMAL_MINUTES=240
# OPS_PENDING_BACKLOG_THRESHOLD=10
# OPS_PENDING_BACKLOG_MINUTES=120
# OPS_REJECTION_SPIKE_RATE=0.2
# OPS_CONSULT_FAILURE_SPIKE_THRESHOLD=5
# API_DOCS_KEY=replace-to-enable-swagger-in-staging-prod
# ERROR_TRACKING_WEBHOOK_URL=
# MONITORING_ALERT_WEBHOOK_URL=   # Slack/PagerDuty — preferred for production alerts
# MONITORING_ENABLED=true
# ALERT_DEDUP_WINDOW_MS=900000    # 15 min duplicate suppression
# ALERT_ESCALATION_THRESHOLD=5    # Re-notify after N repeats in window
# ALERT_MAX_CRITICAL_PER_MIN=10
# ALERT_MAX_WARNING_PER_MIN=30
# ALERT_MAX_INFO_PER_MIN=60
# Sentry (optional — leave SENTRY_DSN empty for local dev)
# SENTRY_ENABLED=true
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# APP_ENV=development

# ============================================
# Startup
# ============================================
# SKIP_STARTUP_VALIDATION=true

# Foundation modules (default: stub modules animals/clinics/notifications are NOT mounted)
# FOUNDATION_MOUNT_STUB_MODULES=true
# WAIT_FOR=postgres
# WAIT_FOR=postgres,redis,minio
# WAIT_MAX_ATTEMPTS=30
# WAIT_DELAY_MS=2000

# ============================================
# Docker (optional — CI / teams that use compose)
# ============================================
# npm run docker:up
